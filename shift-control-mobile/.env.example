# =============================================================================
# Shift Control Mobile — Environment Variables
# =============================================================================
#
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or .env to version control.
# This file (.env.example) IS committed as documentation.
#
# IMPORTANT: EXPO_PUBLIC_* variables are BUNDLED INTO THE APP.
# Do NOT put secrets, tokens, or passwords in EXPO_PUBLIC_* variables.
# These values are visible in the compiled app binary.
#
# =============================================================================

# Backend API base URL for local development
EXPO_PUBLIC_API_BASE_URL=http://localhost:8080
