### VS Code ###
.vscode/

### Secrets & local config (NEVER commit credentials) ###
# Ignore all .env variants
.env
.env.*
# But allow example files — these are documentation, not secrets
!.env.example
!.env.*.example
# Legacy patterns (belt-and-suspenders)
.env.local
.env.*.local
# Spring profile files that may contain credentials
application-local.properties
application-local.yml
application-local.yaml
application-dev.properties
application-dev.yml
application-prod.properties
application-prod.yml
# Backend-scoped env files
backend/.env
backend/.env.*
!backend/.env.example
!backend/.env.*.example
# Mobile-scoped env files (handled in shift-control-mobile/.gitignore too)
shift-control-mobile/.env
shift-control-mobile/.env.*
!shift-control-mobile/.env.example
!shift-control-mobile/.env.*.example

### Docker local overrides ###
docker-compose.override.yml

### Logs ###
*.log
logs/
spring-shell.log

### OS files ###
.DS_Store
Thumbs.db
desktop.ini
ehthumbs.db
