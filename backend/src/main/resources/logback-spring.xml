<?xml version="1.0" encoding="UTF-8"?>
<configuration>

    <!--
        Console-based logging for Render (stdout).
        Log levels are configured via application.properties (logging.level.*).
        The requestId comes from RequestIdFilter via SLF4J MDC.
        Format: timestamp level [thread] logger [rid=<requestId>] message
    -->

    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} %-5level [%thread] %logger{36} [rid=%X{requestId:-none}] %msg%n</pattern>
        </encoder>
    </appender>

    <root level="INFO">
        <appender-ref ref="CONSOLE"/>
    </root>

</configuration>
