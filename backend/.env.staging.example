# =============================================================================
# Shift Control — Backend Staging Environment Variables
# =============================================================================
#
# Example for Render staging environment.
# Configure these values in the Render environment variables panel.
# NEVER commit .env.staging with real credentials.
#
# =============================================================================

SPRING_PROFILES_ACTIVE=staging

# Supabase PostgreSQL — sslmode=require is mandatory
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=<supabase-db-password>

# Generate with: openssl rand -base64 64
JWT_SECRET=<minimum-32-bytes-secure-random>
JWT_EXPIRATION_SECONDS=43200

# Required — application will not start without this
CORS_ALLOWED_ORIGINS=https://shift-control-staging.onrender.com

# -----------------------------------------------------------------------------
# FIRST-ADMIN BOOTSTRAP
# -----------------------------------------------------------------------------
#
# BOOTSTRAP_ADMIN_ENABLED=true only during first deploy to a clean staging DB.
# After the first admin is created:
#   1. Log in and verify access.
#   2. Set BOOTSTRAP_ADMIN_ENABLED=false in Render.
#   3. Restart the service.
# The password is temporary. Change it through the admin management flow after first login.

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Initial Admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_FAIL_IF_EXISTS=false
