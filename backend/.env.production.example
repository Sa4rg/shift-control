# =============================================================================
# Shift Control — Backend Production Environment Variables
# =============================================================================
#
# Example for Render production environment.
# Configure these values in the Render environment variables panel.
# NEVER commit .env.production with real credentials.
#
# =============================================================================

SPRING_PROFILES_ACTIVE=prod

# Supabase PostgreSQL — sslmode=require is mandatory
DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
DATABASE_USERNAME=postgres
DATABASE_PASSWORD=<supabase-db-password>

# Generate with: openssl rand -base64 64
JWT_SECRET=<minimum-32-bytes-secure-random>
JWT_EXPIRATION_SECONDS=43200

# Required — application will not start without this
# Use only real production origins (admin web client, etc.)
# Do NOT use wildcard (*)
CORS_ALLOWED_ORIGINS=https://admin.your-domain.com

# -----------------------------------------------------------------------------
# FIRST-ADMIN BOOTSTRAP
# -----------------------------------------------------------------------------
#
# BOOTSTRAP_ADMIN_ENABLED=true only during first deploy to a clean production DB.
# This must be turned off immediately after the first admin is created.
# Never leave bootstrap enabled in production.
# The password must be strong (12+ characters) and temporary.
# Change or rotate it through the admin management flow after first login.

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Initial Admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_FAIL_IF_EXISTS=false
