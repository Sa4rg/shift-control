# =============================================================================
# Shift Control — Backend Environment Variables
# =============================================================================
#
# Copy this file to .env and fill in real values.
# NEVER commit .env to version control.
# This file (.env.example) IS committed as documentation.
#
# =============================================================================

# -----------------------------------------------------------------------------
# SPRING PROFILE
# -----------------------------------------------------------------------------
# Options: dev | staging | prod
# Example for local development:
#   SPRING_PROFILES_ACTIVE=dev
# Example for Render:
#   Set via Render environment variables panel (not in a file)

SPRING_PROFILES_ACTIVE=dev

# -----------------------------------------------------------------------------
# DATABASE
# -----------------------------------------------------------------------------
#
# Local PostgreSQL (dev) format:
#   DATABASE_URL=jdbc:postgresql://localhost:5432/shift_control
#
# Supabase PostgreSQL (staging/prod) format:
#   DATABASE_URL=jdbc:postgresql://db.<project-ref>.supabase.co:5432/postgres?sslmode=require
#
# The ?sslmode=require is mandatory for Supabase connections.

DATABASE_URL=jdbc:postgresql://localhost:5432/shift_control
DATABASE_USERNAME=shift_control_user
DATABASE_PASSWORD=change_me_local_password

# -----------------------------------------------------------------------------
# JWT
# -----------------------------------------------------------------------------
#
# JWT_SECRET: minimum 32 bytes of random content.
# Generate a secure secret with:
#   openssl rand -base64 64
# OR:
#   node -e "console.log(require('crypto').randomBytes(64).toString('base64'))"
#
# JWT_EXPIRATION_SECONDS:
#   Development default: 86400 (24 hours) — set in application-dev.properties
#   Staging/Production default: 43200 (12 hours)
#   Refresh tokens are not implemented yet; revisit before wider production.

JWT_SECRET=change_me_this_must_be_at_least_32_bytes_long_replace_with_secure_random
JWT_EXPIRATION_SECONDS=86400

# -----------------------------------------------------------------------------
# CORS
# -----------------------------------------------------------------------------
#
# CORS_ALLOWED_ORIGINS is REQUIRED in staging and production.
# If empty or missing in staging/prod, the application will fail to start.
#
# Local development example (not required when profile=dev — set in application-dev.properties):
#   CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081
#
# Staging example:
#   CORS_ALLOWED_ORIGINS=https://shift-control-staging.onrender.com
#
# Production example:
#   CORS_ALLOWED_ORIGINS=https://admin.your-domain.com
#
# Do NOT use wildcard (*) in staging or production.

CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000,http://localhost:8081

# -----------------------------------------------------------------------------
# FIRST-ADMIN BOOTSTRAP
# -----------------------------------------------------------------------------
#
# BOOTSTRAP_ADMIN_ENABLED must only be true during the first deploy to a clean DB.
# After the first admin is created, set it to false and restart the service.
# The password must be temporary, strong (12+ characters), and rotated immediately.
#
# Leave disabled (false) for local development unless bootstrapping a fresh DB.

BOOTSTRAP_ADMIN_ENABLED=false
BOOTSTRAP_ADMIN_USERNAME=
BOOTSTRAP_ADMIN_PASSWORD=
BOOTSTRAP_ADMIN_FULL_NAME=Initial Admin
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_FAIL_IF_EXISTS=false
